# Walter mobile env. Copy to .env and fill in.
# Expo exposes only EXPO_PUBLIC_-prefixed vars to the app.

# Base URL the app hits for /api/* (your Vercel deployment).
EXPO_PUBLIC_API_BASE_URL=https://scoutie.vercel.app

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_MAPBOX_TOKEN=
